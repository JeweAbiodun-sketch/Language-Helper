{
  "expo": {
    "name": "Language Helper",
    "slug": "language-helper",
    "scheme": "languagehelper",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#11141C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.languagehelper.app"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "language-helper.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "80f78a95-1df2-43dd-959f-b7c946e723eb"
      }
    }
  }
}
